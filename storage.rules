rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /attendancePhotos/{employeeId}/{fileName} {
      allow read: if true;
      allow write: if request.resource.size < 5 * 1024 * 1024   // max 5MB
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
